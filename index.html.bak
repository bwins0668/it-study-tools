</head>

<body>



  <!-- App Container -->

  <div class="app-container">



    <!-- Header Panel -->

    <header class="app-header">

      <div class="header-logo">

        <i class="fa-solid fa-graduation-cap logo-icon" id="main-logo-icon"></i>

        <div class="logo-text">

          <h1 id="main-title-text">Study Tools</h1>

          <span>驟榊･怜､・・ｹｳ蜿ｰ &nbsp;窶｢&nbsp; By: Coco</span>

        </div>

      </div>



      <!-- Subject Tab Switcher -->

      <div class="header-subject-selector" onclick="event.stopPropagation()">

        <button class="subject-tab active" id="subject-tab-sql" onclick="switchSubject('sql')">

          <i class="fa-solid fa-database"></i> SQL 蟄ｦ荵

        </button>

        <button class="subject-tab" id="subject-tab-java" onclick="switchSubject('java')">

          <i class="fa-brands fa-java"></i> Java 蟄ｦ鄙・

        </button>

        <button class="subject-tab" id="subject-tab-python" onclick="switchSubject('python')">

          <i class="fa-brands fa-python"></i> Python 蟄ｦ荵

        </button>

        <button class="subject-tab" id="subject-tab-itpass" onclick="switchSubject('itpass')">

          <i class="fa-solid fa-graduation-cap"></i> IT繝代せ繝昴・繝・螟・・

        </button>

        <button class="subject-tab" id="subject-tab-sg" onclick="switchSubject('sg')">

          <i class="fa-solid fa-shield-halved"></i> SG 螟・・

        </button>

        <button class="subject-tab" id="subject-tab-typing" onclick="switchSubject('typing')">

          <i class="fa-solid fa-keyboard"></i> 謇灘ｭ礼ｻ・ｹ

        </button>

      </div>      
      <button class="theme-toggle-btn" id="theme-toggle-btn" onclick="toggleTheme()" title="切换浅色/深色模式">
        <i class="fa-solid fa-sun"></i>
      </button>
      <button class="ai-settings-btn" id="ai-settings-btn" onclick="openAiSettings()" title="AI隶ｾ鄂ｮ / AI Settings">

        <i class="fa-solid fa-robot"></i> <span>AI隶ｾ鄂ｮ</span>

      </button>



      <!-- Header Challenge Widget (SQL only) -->

      <div class="header-challenge" id="header-challenge">

        <button class="header-challenge-btn-start" id="challenge-start-btn" onclick="startCrossChallenge()">

          <i class="fa-solid fa-fire-flame-curved"></i> 扈ｼ蜷磯囂譛ｺ謖第・

        </button>

        <div class="challenge-active-controls" id="challenge-controls" style="display: none;">

          <span class="challenge-status-text" id="challenge-status-text">謖第・荳ｭ (1/1)</span>

          <span class="challenge-source-tag" id="challenge-source-tag" style="display: none;"></span>

          <button class="challenge-control-btn" id="challenge-next-btn" onclick="nextCrossChallenge()" style="display: none;">

            <i class="fa-solid fa-forward"></i> 謐｢荳鬚・

          </button>

          <button class="challenge-control-btn stop-btn" id="challenge-stop-btn" onclick="stopCrossChallenge()" style="display: none;">

            <i class="fa-solid fa-stop"></i> 扈捺據

          </button>

        </div>

      </div>



      <button class="reset-all-btn" onclick="resetAllProgress()">

        <i class="fa-solid fa-rotate-left"></i> 驥咲ｽｮ霑帛ｺｦ

      </button>

    </header>



    <!-- Sub-Header Bar (Visible in SQL mode to toggle Textbook vs Mock Exam) -->

