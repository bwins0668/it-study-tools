                <div class="pass-status-badge pass" id="coding-pass-badge" style="font-size: 18px; font-weight: 800; padding: 4px 16px; border-radius: 6px; width: fit-content; text-shadow: 0 0 8px rgba(16, 185, 129, 0.4);">蜷域ｼ</div>

                <div class="score-display" style="margin-top: 8px;">

