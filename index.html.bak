              <button class="pdf-minimize-btn" id="pdf-minimize-btn" onclick="toggleMinimizePdf()" style="background: transparent; border: 1px solid rgba(255, 255, 255, 0.15); color: var(--text-muted); padding: 6px 14px; border-radius: 6px; font-size: 12px; cursor: pointer; display: flex; align-items: center; gap: 6px; transition: var(--transition-smooth);">

