                  <i class="fa-solid fa-arrows-rotate"></i> 謐｢荳鬚・

                </button>

                <button class="console-btn random-practice-btn" id="random-practice-btn" onclick="toggleRandomPractice()">

                  <i class="fa-solid fa-shuffle"></i> 髫乗惻謖・ｻ､扈・ｹ

                </button>

