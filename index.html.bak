                <pre style="background: #030712; border: 1px solid rgba(255,255,255,0.05); padding: 12px; border-radius: 6px; overflow-x: auto; font-family: 'Fira Code', monospace; font-size: 13px; color: #ff9e64;" id="eq-expected-output">Expected output goes here...</pre>

              </div>

            </div>

          </div>



          <!-- Inline Actions for current question -->

          <div class="eq-actions-row" style="display: flex; justify-content: space-between; align-items: center; background: rgba(255,255,255,0.02); padding: 12px 18px; border-radius: 8px; border: 1px solid var(--border-color); margin-top: 8px;">

            <div class="eq-verify-status-box" style="display: flex; align-items: center; gap: 8px; font-size: 13px;">

              <span>豬玖ｯ慕憾諤・ </span>

              <span class="verify-status-badge" id="eq-verify-status-badge" style="background: rgba(255,255,255,0.05); padding: 3px 8px; border-radius: 4px; font-weight: 600; color: var(--text-muted);">譛ｪ菴懃ｭ・(譛ｪ逹謇・</span>

            </div>

            

            <button class="eq-verify-btn" onclick="verifyCurrentCodingQuestion()" style="padding: 8px 16px; background: linear-gradient(135deg, #7c3aed, #a855f7); color: #fff; border: none; border-radius: 6px; font-size: 13px; font-weight: 600; cursor: pointer; display: flex; align-items: center; gap: 6px; box-shadow: 0 4px 10px rgba(168, 85, 247, 0.2); transition: var(--transition-smooth);">

